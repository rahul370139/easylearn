# Copy to `backend.env` on the VPS (do not commit real secrets)
#
#   cp backend.env.example backend.env
#   nano backend.env

GROQ_API_KEY=
COHERE_API_KEY=

# Supabase (backend uses the same env var names as the frontend integration)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional: only if you add server-side admin operations later (do NOT expose to browsers)
# SUPABASE_SERVICE_ROLE_KEY=
